{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress"],
  "mutate": [
    "src/**/*.{ts,tsx}",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/*.fake.ts",
    "!src/test-setup.ts",
    "!src/vite-env.d.ts",
    "!src/main.tsx"
  ],
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  }
}
